<launch>

  <arg name="x_pos" default="1.28"/>
  <arg name="y_pos" default="3.12"/>
  <arg name="z_pos" default="0.06"/>
  <arg name="roll" default="0" />
  <arg name="pitch" default="0" />
  <arg name="yaw" default="-1.568" />



  <param name="robot_description" command="$(find xacro)/xacro --inorder $(find robot_description)/urdf/robot_description.urdf.xacro" />

  <node pkg="gazebo_ros" type="spawn_model" name="spawn_urdf" args="-urdf -model robot_description 
  -x $(arg x_pos) -y $(arg y_pos) -z $(arg z_pos)   -R $(arg roll) -P $(arg pitch) -Y $(arg yaw) -param robot_description" 
  output="screen"/>
  <!-- 启动机器人状态和关节状态发布节点 -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" />
  <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher" />


  <!-- 启动图形化的控制关节运动节点 -->
  <node pkg="joint_state_publisher_gui" type="joint_state_publisher_gui" name="joint_state_publisher_gui" />

  <node name="rviz" pkg="rviz" type="rviz" output="screen"
          args="-d $(find robot_simulation)/rviz/car.rviz"/>

  <node pkg="rqt_tf_tree" type="rqt_tf_tree" name="rqt_tf_tree" />

</launch>
